#!/usr/bin/env bash
#
# post-checkout: auto-restore the PRIMARY checkout to `main` when it leaves it.
#
# The primary checkout (repo root, NOT a worktree under .claude/worktrees/) is
# the live-deployment build source: `docker compose` builds it from compose.yaml
# + .env at the repo root, so a stray checkout silently changes what the next
# rebuild deploys (docs/dev/CONTRIBUTING.md Section 3). Agent sessions have moved
# it off main repeatedly (#809), so the hook now auto-restores instead of just
# warning.
#
# Override: set MCSD_ALLOW_PRIMARY_BRANCH=1 to suppress auto-restore and allow
# an intentional off-main checkout of the primary checkout (e.g. a human
# inspecting a branch directly). The hook will still print a loud notice.
#
# Dirty-tree guard: if the working tree has uncommitted changes at the time of
# the stray checkout, auto-restore is refused (it would discard those changes).
# Fix: stash or commit, then manually run `git checkout main`.
#
# Detached HEAD: treated the same as a named branch -- auto-restored to main,
# or refused when dirty.
#
# Args (git post-checkout): $1 prev HEAD, $2 new HEAD, $3 flag (1 = branch
# checkout, 0 = file checkout).
set -euo pipefail

# Only react to branch checkouts; file/path checkouts ($3 == 0) never move HEAD.
[ "${3:-0}" = "1" ] || exit 0

toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# Worktrees live under .claude/worktrees/; their checkouts are expected to leave
# main and must stay silent. Only the primary checkout is the deploy source.
case "$toplevel" in
	*/.claude/worktrees/*) exit 0 ;;
esac

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")"
[ "$branch" = "main" ] && exit 0

# Colour helpers (only when stderr is a terminal).
if [ -t 2 ]; then
	red=$'\033[1;31m'
	yellow=$'\033[1;33m'
	reset=$'\033[0m'
else
	red=""
	yellow=""
	reset=""
fi

ref="${branch:-detached HEAD ($(git rev-parse --short HEAD 2>/dev/null || echo unknown))}"

# Allow intentional override: MCSD_ALLOW_PRIMARY_BRANCH=1 skips auto-restore.
if [ "${MCSD_ALLOW_PRIMARY_BRANCH:-0}" = "1" ]; then
	{
		echo
		echo "${yellow}################################################################${reset}"
		echo "${yellow}#  NOTICE: PRIMARY checkout is off 'main' (override active).${reset}"
		echo "${yellow}#    -> ${ref}${reset}"
		echo "${yellow}#  MCSD_ALLOW_PRIMARY_BRANCH=1 -- auto-restore suppressed.${reset}"
		echo "${yellow}#  Restore manually when done: git checkout main${reset}"
		echo "${yellow}################################################################${reset}"
		echo
	} >&2
	exit 0
fi

# Dirty-tree guard: auto-restore would discard uncommitted work -- refuse instead.
if ! git diff --quiet HEAD 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
	{
		echo
		echo "${red}################################################################${reset}"
		echo "${red}#  ERROR: PRIMARY checkout left 'main' AND has uncommitted work.${reset}"
		echo "${red}#    -> ${ref}${reset}"
		echo "${red}#  Auto-restore aborted to protect your changes.${reset}"
		echo "${red}#  Stash or commit first, then run: git checkout main${reset}"
		echo "${red}################################################################${reset}"
		echo
	} >&2
	exit 1
fi

# Auto-restore: switch the primary checkout back to main.
{
	echo
	echo "${red}################################################################${reset}"
	echo "${red}#  AUTO-RESTORE: PRIMARY checkout left 'main'.${reset}"
	echo "${red}#    was: ${ref}${reset}"
	echo "${red}#  The primary checkout is the live-deploy build source.${reset}"
	echo "${red}#  Switching back to main automatically.${reset}"
	echo "${red}#  To allow an off-main checkout, set MCSD_ALLOW_PRIMARY_BRANCH=1${reset}"
	echo "${red}################################################################${reset}"
	echo
} >&2

# Unset the hook path so the recursive checkout does not re-enter this hook.
git -c core.hooksPath="" checkout main
