# Environment for the single-host compose deployment (issue #189).
# Copy to .env and fill every value: `cp .env.example .env`.
# .env is gitignored — it holds secrets and host-specific values. Never commit it.

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=mcsd
POSTGRES_DB=mcsd
# Database password (the api's DB URL is built from it). You MUST set a real
# value: blank/unset makes compose REFUSE to start (the `:?` interpolation in
# compose.yaml). Generate one, e.g.: openssl rand -base64 32
POSTGRES_PASSWORD=

# --- API secrets -----------------------------------------------------------
# JWT signing key for access/refresh tokens. HS256 requires >= 32 bytes.
# You MUST set a real value: blank/unset makes compose REFUSE to start (the
# `:?` interpolation in compose.yaml), so the api never boots with an empty key.
# Generate: openssl rand -base64 48
MCD_API_AUTH__TOKEN__SIGNING_KEY=

# Shared secret the worker presents to authenticate its control-plane stream.
# The worker uses this same value (MCD_WORKER_API_CREDENTIAL in compose.yaml).
# You MUST set a real value: blank/unset makes compose REFUSE to start (the
# `:?` interpolation in compose.yaml), so the control plane never admits an
# unauthenticated worker. Generate: openssl rand -base64 48
MCD_API_CONTROL__WORKER_CREDENTIAL=

# --- Storage backend (issue #702, #940) ------------------------------------
# The shipped default is the `object` backend on the in-compose SeaweedFS S3
# gateway (STORAGE.md Section 7.3). The `seaweedfs` service is gated behind the
# `object` compose profile; COMPOSE_PROFILES below activates it by default, so the
# default experience is "nothing extra to do" — seaweedfs runs and the two S3 keys
# below are required.
#
# COMPOSE_PROFILES selects which profile-gated services run. Leave it as `object`
# for the default object backend. Set it EMPTY (COMPOSE_PROFILES=) together with
# MCD_API_STORAGE__BACKEND=fs to opt back to the local-volume fs backend: that
# drops the seaweedfs service entirely and frees you from the two S3 keys below
# (see docs/dev/DEPLOYMENT.md "Opting back to the fs backend").
COMPOSE_PROFILES=object
#
# The two keys below are the S3 credentials, shared by the api (client) and the
# seaweedfs service (which writes its S3 identities file from them at startup).
# With the default `object` profile active you MUST generate real values: blank
# keys fail loudly at boot — the seaweedfs entrypoint refuses a blank-key identities
# file, and the api's _build_storage refuses the object backend with blank creds
# (naming the variables) — because SeaweedFS authenticates blank-credential clients
# and would otherwise boot a silently unauthenticated store. Generate both, e.g.:
#   openssl rand -hex 16    # access key
#   openssl rand -hex 32    # secret key
# Rotate by changing both values here and recreating the api + seaweedfs services
# (`docker compose up -d --force-recreate api seaweedfs`); existing objects are
# unaffected since the credentials only gate API access, not object encryption.
# (In fs mode these keys are unused; leave them blank.)
MCD_API_STORAGE__OBJECT__ACCESS_KEY=
MCD_API_STORAGE__OBJECT__SECRET_KEY=
# Bucket name (auto-created on first write). Override only if you must.
# MCD_API_STORAGE__OBJECT__BUCKET=mcsd
#
# fs opt-out: edit the COMPOSE_PROFILES line above to COMPOSE_PROFILES= (empty)
# AND add or uncomment: MCD_API_STORAGE__BACKEND=fs
# (see docs/dev/DEPLOYMENT.md "Opting back to the fs backend").
# WARNING: if you set MCD_API_STORAGE__BACKEND=fs but leave COMPOSE_PROFILES=object
# active with blank S3 keys, seaweedfs will FATAL-loop and the api will block on
# its healthy-wait — set COMPOSE_PROFILES= (empty) too.
# MCD_API_STORAGE__BACKEND=fs

# --- Worker / container driver --------------------------------------------
# Absolute host path for the worker scratch dir. It is bind-mounted at the SAME
# path inside the worker container (the Docker daemon resolves MC-server binds
# against host paths), so it must be an absolute path.
MCSD_SCRATCH_DIR=/opt/mcsd/scratch

# GID of the host `docker` group, so the worker can use the mounted Docker socket.
# Find it: getent group docker | cut -d: -f3
DOCKER_GID=

# Host interface on which the worker publishes each server's game port.
# Default (unset / 0.0.0.0): all interfaces — players connect directly to this host.
# Relay path: set to 127.0.0.1 so game ports bind loopback-only; the Worker dials
# its own loopback into the tunnel and no inbound game-port range is needed.
# MCD_WORKER_GAME_BIND_IP=127.0.0.1

# --- Relay (epic #659, issue #960) -----------------------------------------
# The game ingress relay is opt-in. To enable it, add `relay` to
# COMPOSE_PROFILES above (e.g. COMPOSE_PROFILES=object,relay) and fill the
# required variables below. See docs/dev/DEPLOYMENT.md "Relay" for full setup
# (wildcard DNS, TLS material, worker game_bind_ip guidance).
#
# Shared secret the relay presents to authenticate against the API RelayService.
# Also set on the relay side as MCD_RELAY_API_CREDENTIAL (see compose.yaml).
# compose uses `:-` so it does NOT refuse a blank value here — the relay binary
# itself fails fast at startup when this is empty. Generate: openssl rand -base64 48
MCD_API_RELAY__CREDENTIAL=
#
# Master switch on the API side. Set true to serve RelayService, expose
# join_hostname per server, and run the session prune loop.
# (API config key: relay.enabled — env_prefix=MCD_API_, delimiter=__)
MCD_API_RELAY__ENABLED=false
#
# Base domain for the wildcard DNS record, e.g. mc.example.com. The API builds
# per-server join hostnames as <slug>.<base_domain>.
# (API config key: relay.base_domain — env_prefix=MCD_API_, delimiter=__)
MCD_API_RELAY__BASE_DOMAIN=
#
# Bedrock ingress capability gate (epic #1540, issue #1541). Set true to let
# Geyser detection allocate a server's bedrock_port and surface
# bedrock_address/bedrock_port on server responses; also publish the relay's
# Bedrock UDP ports (see compose.yaml's relay service) and open the inbound UDP
# window on the relay host firewall. See docs/app/BEDROCK.md and
# docs/dev/DEPLOYMENT.md "Relay" for the full setup and manual verification.
# (API config key: relay.bedrock_enabled — env_prefix=MCD_API_, delimiter=__)
MCD_API_RELAY__BEDROCK_ENABLED=false
#
# The relay's publicly reachable tunnel endpoint (host:port) advertised to
# Workers so they know where to dial back. Typically the API host, port 25665.
# Must be non-empty when the `relay` profile is active.
MCD_RELAY_TUNNEL_PUBLIC_ENDPOINT=
#
# Host directory containing tunnel-cert.pem and tunnel-key.pem (the relay's
# tunnel listener TLS material). Bind-mounted read-only into the relay container
# at /etc/mcsd/. Self-signed is fine; the CA travels in-band to Workers.
# Generate once: see docs/dev/DEPLOYMENT.md "Relay — TLS material".
MCD_RELAY_TLS_DIR=/etc/mcsd/relay

# --- Cloudflare Tunnel (optional, issue #1090) -----------------------------
# Cloudflare Tunnel provides HTTPS access to the dashboard without opening
# inbound ports or managing TLS certificates. The tunnel is configured in the
# Cloudflare Zero Trust dashboard (https://one.dash.cloudflare.com/).
#
# To enable: add `tunnel` to COMPOSE_PROFILES above (e.g. COMPOSE_PROFILES=object,tunnel)
# and set the tunnel token below.
#
# Create a tunnel in the Cloudflare dashboard, add a public hostname pointing to
# `http://api:8000`, and copy the tunnel token here.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Published host ports --------------------------------------------------
# Host port for the API HTTP surface (REST + data-plane). The gRPC control
# plane (50051) is not published: the in-compose worker reaches it over the
# internal network. A cross-host worker requires control-plane TLS first
# (see docs/dev/DEPLOYMENT.md).
API_HTTP_PORT=8000

# --- Reconciler tuning (issue #985) ----------------------------------------
# After an API restart, servers whose observed state was reset to unknown
# stay unjoinable via the relay for the full grace window (issue #985).
# To speed self-heal on single-host deployments where the worker reconnects
# in seconds, lower HELD_START_GRACE_SECONDS (default 90 s). This shortens
# the grace only for servers whose start was already held by the API, which
# is the common restart case; the full GRACE_SECONDS (660 s) still protects
# cold starts that may need hydrate + snapshot time.
# Do NOT lower GRACE_SECONDS below its safety floor (~630 s) — doing so
# triggers a boot-time warning and risks duplicate-start / stale-snapshot
# races.  See docs/dev/DEPLOYMENT.md Section 12 for details.
# MCD_API_RECONCILER__GRACE_SECONDS=660
# MCD_API_RECONCILER__HELD_START_GRACE_SECONDS=90
# MCD_API_RECONCILER__INTERVAL_SECONDS=60
# MCD_API_RECONCILER__BACKOFF_BASE_SECONDS=30
# MCD_API_RECONCILER__BACKOFF_MAX_SECONDS=3600

# --- Game-port range (issue #1002) -----------------------------------------
# Inclusive range the API auto-assigns each server's game port from. Defaults
# match the built-in window (25565..25664). In relay mode the API already
# excludes the relay's host binds (game 25565, tunnel 25665) from this range,
# so this is only a fallback knob for shifting the range. Leave commented to
# use the defaults.
# MCD_API_PORTS__RANGE_START=25565
# MCD_API_PORTS__RANGE_END=25664
