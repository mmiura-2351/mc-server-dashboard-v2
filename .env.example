# Environment for the single-host compose deployment (issue #189).
# Copy to .env and fill every value: `cp .env.example .env`.
# .env is gitignored — it holds secrets and host-specific values. Never commit it.

# --- PostgreSQL ------------------------------------------------------------
POSTGRES_USER=mcsd
POSTGRES_DB=mcsd
# Database password. Generate one, e.g.: openssl rand -base64 32
POSTGRES_PASSWORD=

# --- API secrets -----------------------------------------------------------
# JWT signing key for access/refresh tokens. HS256 requires >= 32 bytes.
# Generate: openssl rand -base64 48
MCD_API_AUTH__TOKEN__SIGNING_KEY=

# Shared secret the worker presents to authenticate its control-plane stream.
# The worker uses this same value (MCD_WORKER_API_CREDENTIAL in compose.yaml).
# Generate: openssl rand -base64 48
MCD_API_CONTROL__WORKER_CREDENTIAL=

# --- Storage backend (issue #702) -----------------------------------------
# The shipped default is the `object` backend on the in-compose SeaweedFS S3
# gateway (STORAGE.md Section 7.3). The two keys below are the S3 credentials;
# they are shared by the api (client) and the seaweedfs service (which writes its
# S3 identities file from them at startup).
#
# You MUST generate real values: blank/unset keys make compose REFUSE to start
# (the `:?` interpolation in compose.yaml), because SeaweedFS authenticates
# blank-credential clients and would otherwise boot a silently unauthenticated
# store. Generate both, e.g.:
#   openssl rand -hex 16    # access key
#   openssl rand -hex 32    # secret key
# Rotate by changing both values here and recreating the api + seaweedfs services
# (`docker compose up -d --force-recreate api seaweedfs`); existing objects are
# unaffected since the credentials only gate API access, not object encryption.
MCD_API_STORAGE__OBJECT__ACCESS_KEY=
MCD_API_STORAGE__OBJECT__SECRET_KEY=
# Bucket name (auto-created on first write). Override only if you must.
# MCD_API_STORAGE__OBJECT__BUCKET=mcsd
#
# To run the local-volume fs backend INSTEAD of object, uncomment this (see
# docs/dev/DEPLOYMENT.md "Opting back to the fs backend"). The seaweedfs service
# still runs and still requires the two keys above to be set, so generate them
# regardless:
# MCD_API_STORAGE__BACKEND=fs

# --- Worker / container driver --------------------------------------------
# Absolute host path for the worker scratch dir. It is bind-mounted at the SAME
# path inside the worker container (the Docker daemon resolves MC-server binds
# against host paths), so it must be an absolute path.
MCSD_SCRATCH_DIR=/opt/mcsd/scratch

# GID of the host `docker` group, so the worker can use the mounted Docker socket.
# Find it: getent group docker | cut -d: -f3
DOCKER_GID=

# --- Published host ports --------------------------------------------------
# Host port for the API HTTP surface (REST + data-plane). The gRPC control
# plane (50051) is not published: the in-compose worker reaches it over the
# internal network. A cross-host worker requires control-plane TLS first
# (see docs/dev/DEPLOYMENT.md).
API_HTTP_PORT=8000
