{
  "name": "webui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24",
    "npm": "11.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "bench": "vitest bench",
    "e2e": "playwright test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -b",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "openapi:export": "cd ../api && uv run python -m mc_server_dashboard_api.export_openapi ../webui/openapi.json",
    "openapi:generate": "openapi-typescript ./openapi.json --output ./src/api/schema.ts",
    "openapi": "npm run openapi:export && npm run openapi:generate"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "fflate": "^0.8.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "openapi-typescript": {
      "typescript": "$typescript"
    },
    "js-yaml": "^4.2.0"
  }
}
